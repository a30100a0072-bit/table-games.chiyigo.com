{
  "name": "big-two-game",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:workers": "vitest run --config vitest.workers.config.mts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "deploy": "wrangler deploy --env production",
    "gen:jwk": "node scripts/gen-jwk.mjs",
    "db:migrate:local":      "wrangler d1 migrations apply big-two-db --local",
    "db:migrate:prod":       "wrangler d1 migrations apply big-two-db --env production --remote",
    "db:migrate:list:local": "wrangler d1 migrations list  big-two-db --local",
    "db:migrate:list:prod":  "wrangler d1 migrations list  big-two-db --env production --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260430.1",
    "@vitest/runner": "^4.1.5",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
